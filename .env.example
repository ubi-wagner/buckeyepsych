# ---- Required ----

# PostgreSQL connection string. Railway provides this automatically when you
# attach a Postgres plugin to the service.
DATABASE_URL="postgresql://user:pass@localhost:5432/buckeyepsych"

# Session cookie encryption secret. MUST be at least 32 characters.
# Generate with:  openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars!!"

# Bootstrap admin credentials. Used ONLY for the very first login when the
# User table is empty. After the first successful login the user is created
# and you should change the password from inside the app.
ADMIN_EMAIL="admin@buckeyepsych.com"
ADMIN_PASSWORD="change-me-on-first-login"

# Directory where uploaded files (PDF forms, images) are written.
# On Railway, attach a Volume and mount it at /data, then set this to /data/uploads
UPLOAD_DIR="./data/uploads"

# ---- Optional ----

# Canonical public URL (used in metadata)
NEXT_PUBLIC_SITE_URL="https://www.buckeyepsych.com"
